---
// projects.astro

import projectItems from './Projects/projectItems';
import { ExternalLink, Github } from 'lucide-astro';
---

<section
  id="projects"
  class="animate-fade-in-up py-16 px-4
         bg-gradient-to-b from-white via-indigo-50 to-white
         dark:bg-gradient-to-b dark:from-gray-900 dark:via-gray-800 dark:to-gray-900
         text-gray-900 dark:text-white
         transition-colors duration-300"
>
<div class="text-center mb-8">
  <h2 class="text-4xl font-bold text-gray-900 dark:text-white">Projects</h2>
  <div class="w-20 h-1 bg-gradient-to-r from-blue-600 to-purple-600 mx-auto mt-2 rounded-full"></div>
</div>

<!-- フィルターボタン -->
<div class="flex justify-center gap-3 mb-8 flex-wrap">
  <button
    class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-blue-600 text-white"
    data-filter="all"
  >
    すべて
  </button>
  <button
    class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900"
    data-filter="Webアプリ"
  >
    Webアプリ
  </button>
  <button
    class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900"
    data-filter="ゲーム"
  >
    ゲーム
  </button>
  <button
    class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900"
    data-filter="デスクトップアプリ"
  >
    デスクトップアプリ
  </button>
  <button
    class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900"
    data-filter="モバイルアプリ"
  >
    モバイルアプリ
  </button>
</div>

<div class="max-w-5xl mx-auto space-y-6">
  {projectItems.map((project) => (
    <div class="project-item project-card rounded-2xl overflow-hidden transition-all duration-300" data-tag={project.tag}>
      <div class="flex flex-col md:flex-row bg-white dark:bg-gray-800 md:min-h-[280px]">
        <!-- 左: 画像 / アイコン -->
        <div class={`md:w-96 w-full h-56 md:h-64 flex-shrink-0 bg-gradient-to-br ${project.gradientFrom} ${project.gradientTo} dark:from-gray-700 dark:to-gray-600 flex items-center justify-center overflow-hidden`}>
          <img src={project.image} alt={project.title} class="w-full h-full object-contain" />
        </div>

        <!-- 右: テキスト -->
        <div class="flex-1 p-6 flex flex-col">
          <div class="flex items-center gap-3 mb-2">
            <h3 class="text-xl font-bold">{project.title}</h3>
            <span class="px-2 py-0.5 rounded-full text-xs bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300">{project.tag}</span>
          </div>
          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">担当：{project.role}</p>
          <p class="text-sm text-gray-700 dark:text-gray-300 mb-4 leading-relaxed">{project.description}</p>

          <div class="mt-auto">
            <div class="flex flex-wrap gap-2 mb-4">
              {project.techStack.map((tech) => (
                <span class="px-2 py-1 rounded text-xs bg-[#f4f4f5] dark:bg-gray-700">{tech}</span>
              ))}
            </div>

            <div class="flex items-center gap-3">
              <a
                href={project.liveDemoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white px-4 py-2 rounded text-sm hover:shadow-md hover:scale-105 transition-all duration-300"
              >
                <ExternalLink class="w-4 h-4" /> <span>デモを見る</span>
              </a>
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-white dark:bg-black border border-gray-300 dark:border-gray-600 px-3 py-2 rounded hover:scale-110 transition-transform duration-300"
              >
                <Github class="w-4 h-4 dark:text-white text-black" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

</section>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const allItems = document.querySelectorAll('.project-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // ボタンのスタイルを更新
      filterBtns.forEach(b => {
        if (b === btn) {
          b.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
          b.classList.add('bg-blue-600', 'text-white');
        } else {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');
        }
      });

      // フィルター適用
      allItems.forEach(item => {
        const tag = item.dataset.tag;
        if (filter === 'all' || tag === filter) {
          item.classList.remove('hidden');
        } else {
          item.classList.add('hidden');
        }
      });
    });
  });
</script>

<style>
  .project-card {
    box-shadow:
      8px 8px 20px #d1d5e0,
      -8px -8px 20px #ffffff;
  }
  .project-card:hover {
    box-shadow:
      12px 12px 28px #d1d5e0,
      -12px -12px 28px #ffffff;
    transform: translateY(-4px);
  }

  :global(.dark) .project-card {
    box-shadow:
      8px 8px 20px #151c28,
      -8px -8px 20px #27324e;
  }
  :global(.dark) .project-card:hover {
    box-shadow:
      12px 12px 28px #151c28,
      -12px -12px 28px #27324e;
    transform: translateY(-4px);
  }
</style>
