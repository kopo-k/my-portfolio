---
// About.astro
import { Star, User } from "lucide-astro";
---
<section id="about" class="animate-fade-in-up bg-gradient-to-b from-white via-indigo-50 to-white
         dark:bg-gradient-to-b dark:from-gray-900 dark:via-gray-800 dark:to-gray-900
         text-gray-900 dark:text-white
         transition-colors duration-300">

  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-bold text-gray-900 dark:text-white">About Me</h2>
      <div class="w-20 h-1 bg-gradient-to-r from-blue-600 to-purple-600 mx-auto mt-2 rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-start">
      <!-- Left: About Text -->
      <div class="space-y-10">
        <!-- Currently Learning -->
        <div>
          <h3 class="text-2xl font-semibold flex items-center text-gray-900 dark:text-white mb-3 group">
            <Star class="w-6 h-6 text-blue-600 mr-2 group-hover:rotate-12 transition-transform duration-300" />
            <p class="group-hover:text-blue-600 transition-colors duration-300">現在学習中</p>
          </h3>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            個人開発で「tamado」というWebアプリを開発中です。現在はGCP（Cloud Run）にデプロイしており、今後Fastify + Prismaによるバックエンド追加とCloud SQL（PostgreSQL）の導入を予定しています。リソース管理にはTerraformを導入し、インフラをコードで管理する手法を学んでいます。フロントエンドだけでなく、バックエンドやインフラまで一貫して構築できるエンジニアを目指しています。
          </p>
        </div>

        <!-- Future Goals -->
        <div>
          <h3 class="text-2xl font-semibold flex items-center text-gray-900 dark:text-white mb-3 group">
            <Star class="w-6 h-6 text-blue-600 mr-2 group-hover:rotate-12 transition-transform duration-300" />
            <p class="group-hover:text-blue-600 transition-colors duration-300">
              将来の目標
            </p>
          </h3>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            私が目指すのは、チームの生産性を仕組みで支えるSREエンジニアです。Dockerでチーム全員の環境構築を一発化したときや、設計図を共有してメンバーの迷いをなくしたときなど、「他人の詰まりを取り除いた瞬間」に最もやりがいを感じてきました。将来的にはAWS・Kubernetes・Terraformといったクラウドの標準技術を深く理解した上で、「あの人に頼めば解決する」と開発チームから自然に頼られる存在を目指しています。
          </p>
        </div>
      </div>

      <!-- Right: Overview Card -->
      <div class="about-card bg-white dark:bg-gray-800 p-8 rounded-2xl mt-12 transition-all duration-300">
        <div class="w-16 h-16 bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl flex items-center justify-center mb-6 group">
          <User class="w-8 h-8 text-white group-hover:rotate-12 transition-transform duration-1000" />
        </div>
        <h4 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-blue-600 transition-colors duration-1000">私について</h4>
        <p class="text-gray-700 dark:text-gray-300 ">
          こんにちは、愛知工業大学情報科学部コンピュータシステム専攻の3年、大石大雅です。趣味は映画鑑賞と読書です。大学1年生の5月からプログラミングの学習を始め、2年生からは開発者として成長し続けるために毎日GitHubにコードをコミットしています。
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .about-card {
    box-shadow:
      8px 8px 20px #d1d5e0,
      -8px -8px 20px #ffffff;
  }
  .about-card:hover {
    box-shadow:
      12px 12px 28px #d1d5e0,
      -12px -12px 28px #ffffff;
    transform: translateY(-6px);
  }

  :global(.dark) .about-card {
    box-shadow:
      8px 8px 20px #151c28,
      -8px -8px 20px #27324e;
  }
  :global(.dark) .about-card:hover {
    box-shadow:
      12px 12px 28px #151c28,
      -12px -12px 28px #27324e;
    transform: translateY(-6px);
  }
</style>
